# ⚠️ SECURITY ALERT: DO NOT COMMIT SECRETS TO GIT
# Copy this file to .env and fill in your actual secrets
# Add .env to .gitignore

# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_database_password_here

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_characters

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com


# ─── Google OAuth2 ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id

# ─── Application ─────────────────────────────────────────────────────────────
# Set to production in production environment
APP_ENV=development
